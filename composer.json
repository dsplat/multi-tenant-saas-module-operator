{
    "name": "dsplat/multi-tenant-saas-module-operator",
    "version": "1.0.0",
    "description": "运营人员管理模块 - 独立账号体系、邀请流程、租户映射",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MultiTenantSaas\\Modules\\Operator\\": ""
        }
    },
    "require": {
        "php": "^8.3",
        "dsplat/multi-tenant-saas": "^2.0"
    },
    "extra": {
        "saas": {
            "name": "operator",
            "priority": 5,
            "dependencies": ["auth", "infrastructure"],
            "conflicts": [],
            "requires_core": ">=1.0.0",
            "provider": "MultiTenantSaas\\Modules\\Operator\\OperatorServiceProvider",
            "tenant_toggleable": false,
            "default_enabled": true
        }
    }
}
